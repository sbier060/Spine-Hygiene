{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Spine-IQ",
  "version": "0.2.0",
  "identifier": "com.spineiq.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Spine-IQ",
        "width": 480,
        "height": 760,
        "minWidth": 400,
        "minHeight": 560,
        "resizable": true,
        "visible": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: http://asset.localhost data: blob:; media-src 'self' blob: mediastream:; worker-src 'self' blob:; script-src 'self' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/sbier060/Spine-Hygiene/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDg3Qjg3NUZFNDE4QzI3OTEKUldTUko0eEIvblc0aC9ZTGJTbElKUFVabW11bDJsNHdxMVVUcmlQSm1qZ0dSNThJZXcwZktEU2IK"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "createUpdaterArtifacts": true,
    "category": "HealthcareFitness",
    "shortDescription": "Local, private posture & sitting/standing reminders.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
